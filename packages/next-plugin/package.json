{
  "name": "@wondocs/next-plugin",
  "description": "WonDocs Next.js Plugin - A plugin for integrating WonDocs with Next.js applications.",
  "version": "0.1.0-beta.0",
  "private": false,
  "type": "module",
  "keywords": [
    "documentation",
    "docs",
    "nextjs",
    "plugin",
    "wondocs",
    "mdx",
    "markdown",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wonwon0307/wondocs.git",
    "directory": "packages/next-plugin"
  },
  "license": "UNLICENSED",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@wondocs/core": "workspace:*"
  },
  "peerDependencies": {
    "next": ">=16.0.0"
  },
  "devDependencies": {
    "next": "^16.2.11"
  }
}
