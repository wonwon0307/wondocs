    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@wondocs/core": "workspace:*"
  },
  "peerDependencies": {
    "next": ">=16.0.0"
  },
  "devDependencies": {
    "next": "^16.2.10"
  }
}
