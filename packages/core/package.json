{
  "name": "@wondocs/core",
  "private": true,
  "exports": {
    "./*": {
      "types": "./dist/*/index.d.mts",
      "require": "./dist/*/index.cjs",
      "import": "./dist/*/index.mjs",
      "default": "./dist/*/index.mjs"
    }
  },
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "zod": "^4.4.3"
  }
}
