{
  "name": "@wondocs/core",
  "description": "WonDocs Core - The core essential functionalities and utilities for building documentation websites.",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "keywords": [
    "documentation",
    "docs",
    "core",
    "wondocs",
    "mdx",
    "markdown",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wonwon0307/wondocs.git",
    "directory": "packages/core"
  },
  "license": "UNLICENSED",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "exports": {
    "./config": {
      "types": "./dist/config/index.d.mts",
      "default": "./dist/config/index.mjs"
    },
    "./build": {
      "types": "./dist/build.d.mts",
      "default": "./dist/build.mjs"
    },
    "./watch": {
      "types": "./dist/watch.d.mts",
      "default": "./dist/watch.mjs"
    },
    "./sidebar": {
      "types": "./dist/sidebar.d.mts",
      "default": "./dist/sidebar.mjs"
    },
    "./page": {
      "types": "./dist/page.d.mts",
      "default": "./dist/page.mjs"
    }
  },
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@mdx-js/mdx": "^3.1.1",
    "chokidar": "^5.0.0",
    "gray-matter": "^4.0.3",
    "zod": "^4.4.3"
  }
}
