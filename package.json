{
  "name": "wonwon-docs",
  "version": "1.0.0",
  "packageManager": "pnpm@11.15.1+sha512.81350b07e53c9538a02f1f2303b4290fa2d7be04e56e2a970c4cc4b417dc761de196edabd49d55c7dc9580db81007c44143e4e3d7e462b3000d23c255122d065",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "format": "prettier --write --log-level warn .",
    "lint": "turbo run lint",
    "test": "vitest run",
    "test:dev": "vitest run --watch --coverage",
    "typecheck": "turbo run typecheck",
    "build": "turbo run build",
    "version": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.1",
    "@repo/eslint-config": "workspace:*",
    "@repo/tsconfig": "workspace:*",
    "@repo/vitest-config": "workspace:*",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.0",
    "prettier": "^3.9.6",
    "tsdown": "^0.22.13",
    "turbo": "^2.10.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "lint-staged": {
    "*.{json,md,yml,yaml}": "prettier --check",
    "*.{ts,tsx,js,jsx}": [
      "prettier --check",
      "eslint"
    ]
  }
}
